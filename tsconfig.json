{
  "compilerOptions": {
    "lib": ["es2023"],
    "module": "node20",
    "target": "es2023",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": [
    "./compatibility/**/*.ts",
    "./hardhat.config.ts",
    "./scripts/**/*.ts",
    "./tests/Interoperability.smoke.ts"
  ],
  "exclude": ["node_modules"]
}
