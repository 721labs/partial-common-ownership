{
  "name": "@721labs/partial-common-ownership",
  "version": "0.1.0",
  "description": "This project aims to establish a standard, open source implementation of Partial Common Ownership for non-fungible tokens.",
  "keywords": [
    "harberger tax",
    "partial common ownership",
    "salsa",
    "cost",
    "nft",
    "nfts"
  ],
  "homepage": "https://github.com/721labs/partial-common-ownership",
  "bugs": {
    "url": "https://github.com/721labs/partial-common-ownership/issues"
  },
  "license": "MIT",
  "contributors": [
    {
      "name": "Will Holley",
      "email": "will@willholley.com",
      "url": "https://721.dev"
    }
  ],
  "files": [
    "contracts/Wrapper.sol",
    "contracts/token/**/*.sol",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "repository": "git@github.com:721labs/partial-common-ownership.git",
  "scripts": {
    "console": "hardhat console",
    "compile": "hardhat compile",
    "compiler-warnings:hardhat": "hardhat compile --force && node scripts/check-compiler-warnings.js hardhat",
    "compiler-warnings:forge": "node scripts/check-compiler-warnings.js forge",
    "compiler-warnings:check": "pnpm run compiler-warnings:hardhat && pnpm run compiler-warnings:forge",
    "test:hardhat": "pnpm run test:hardhat:smoke",
    "test:hardhat:smoke": "hardhat typechain && hardhat --network hardhat test tests/Interoperability.smoke.ts",
    "test:forge": "node scripts/check-parity.js",
    "test:safety": "cross-env FOUNDRY_PROFILE=ci node scripts/check-parity.js",
    "test:safety:scheduled": "cross-env FOUNDRY_PROFILE=scheduled node scripts/check-parity.js",
    "test:package": "node scripts/test-package.js",
    "test": "pnpm run test:forge && pnpm run test:hardhat:smoke",
    "prettier": "prettier --write 'contracts/**/*.sol'",
    "solhint": "solhint contracts/*.sol contracts/**/*.sol contracts/**/**/*.sol contracts/**/**/**/*.sol",
    "compatibility": "node scripts/compatibility.js check",
    "compatibility:diff": "node scripts/compatibility.js diff",
    "parity:check": "node scripts/check-parity.js",
    "lock:validate": "node scripts/check-pnpm-lock.js",
    "audit:ratchet": "node scripts/audit-ratchet.js",
    "publish": "npm publish --access public",
    "coverage": "cross-env TYPE_COMPILATION=false hardhat coverage",
    "coverage:forge": "cross-env FOUNDRY_PROFILE=ci node scripts/run-coverage.js",
    "fmt:forge": "forge fmt --check test/solidity/fuzz test/solidity/invariant",
    "gas:check": "node scripts/check-gas.js",
    "safety-baselines:check": "node scripts/check-safety-baselines.js",
    "size:check": "node scripts/check-contract-sizes.js",
    "slither": "node scripts/run-slither.js",
    "typechain": "hardhat typechain"
  },
  "devDependencies": {
    "@ethersproject/abi": "5.6.0",
    "@ethersproject/contracts": "5.6.0",
    "@ethersproject/providers": "5.6.2",
    "@nomiclabs/hardhat-ethers": "2.0.5",
    "@nomiclabs/hardhat-waffle": "2.0.3",
    "@nomiclabs/hardhat-web3": "2.0.0",
    "@openzeppelin/test-helpers": "0.5.15",
    "@typechain/ethers-v5": "10.0.0",
    "@typechain/hardhat": "6.0.0",
    "@types/chai": "4.3.0",
    "@types/js-yaml": "4.0.5",
    "@types/mocha": "9.1.0",
    "@types/node": "16.11.26",
    "chai": "4.3.6",
    "cross-env": "7.0.3",
    "dotenv": "10.0.0",
    "ethereum-waffle": "3.4.4",
    "ethers": "5.6.2",
    "hardhat": "2.28.6",
    "hardhat-gas-reporter": "1.0.8",
    "js-yaml": "4.1.0",
    "prettier": "2.6.2",
    "prettier-plugin-solidity": "1.0.0-beta.19",
    "solhint": "3.3.7",
    "solhint-plugin-prettier": "0.0.5",
    "solidity-coverage": "0.8.0-beta.1",
    "ts-node": "10.7.0",
    "typechain": "8.0.0",
    "typescript": "4.6.3",
    "web3": "1.7.1"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.6.1"
  },
  "packageManager": "pnpm@11.13.1",
  "private": false
}
