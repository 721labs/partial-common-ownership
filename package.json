{
  "name": "@721labs/partial-common-ownership",
  "version": "0.1.0",
  "description": "This project aims to establish a standard, open source implementation of Partial Common Ownership for non-fungible tokens.",
  "keywords": [
    "harberger tax",
    "partial common ownership",
    "salsa",
    "cost",
    "nft",
    "nfts"
  ],
  "homepage": "https://github.com/721labs/partial-common-ownership",
  "bugs": {
    "url": "https://github.com/721labs/partial-common-ownership/issues"
  },
  "license": "MIT",
  "contributors": [
    {
      "name": "Will Holley",
      "email": "will@willholley.com",
      "url": "https://721.dev"
    }
  ],
  "files": [
    "contracts/Wrapper.sol",
    "contracts/token/**/*.sol",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "repository": "git@github.com:721labs/partial-common-ownership.git",
  "type": "module",
  "scripts": {
    "console": "hardhat console",
    "compile": "hardhat build",
    "compiler-warnings:hardhat": "hardhat build --force && node scripts/check-compiler-warnings.cjs hardhat",
    "compiler-warnings:forge": "node scripts/check-compiler-warnings.cjs forge",
    "compiler-warnings:check": "pnpm run compiler-warnings:hardhat && pnpm run compiler-warnings:forge",
    "test:hardhat": "pnpm run test:hardhat:smoke",
    "test:hardhat:smoke": "hardhat build && node --import tsx --test tests/Interoperability.smoke.ts",
    "test:forge": "node scripts/check-parity.cjs",
    "test:safety": "node scripts/check-parity.cjs --profile=ci",
    "test:safety:scheduled": "node scripts/check-parity.cjs --profile=scheduled",
    "test:package": "node scripts/test-package.cjs",
    "test": "pnpm run test:forge && pnpm run test:hardhat:smoke",
    "typecheck": "tsc --noEmit",
    "compatibility": "node scripts/compatibility.cjs check",
    "compatibility:diff": "node scripts/compatibility.cjs diff",
    "parity:check": "node scripts/check-parity.cjs",
    "audit:ratchet": "node scripts/audit-ratchet.cjs",
    "ci:policy": "node scripts/check-ci-policy.cjs",
    "publish": "npm publish --access public",
    "coverage:forge": "node scripts/run-coverage.cjs --profile=ci",
    "fmt:forge": "forge fmt --check test/solidity/fuzz test/solidity/invariant",
    "lint:forge": "node scripts/check-forge-lint.cjs",
    "maintenance:inventory": "node scripts/dependency-inventory.cjs",
    "gas:check": "node scripts/check-gas.cjs",
    "safety-baselines:check": "node scripts/check-safety-baselines.cjs",
    "size:check": "node scripts/check-contract-sizes.cjs",
    "slither": "node scripts/run-slither.cjs"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "4.0.14",
    "@types/node": "24.13.3",
    "ethers": "6.17.0",
    "hardhat": "3.9.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.6.1"
  },
  "packageManager": "pnpm@11.13.1",
  "private": false
}
